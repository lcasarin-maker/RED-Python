#!/usr/bin/env bash
# PRE-PUSH HOOK Coder Cerberus V0.1: Respect @{u} upstream + protocol_cli.py validation

set -e

PROTOCOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PROTOCOL_CLI="$PROTOCOL_DIR/scripts/protocol_cli.py"

BRANCH=$(git rev-parse --abbrev-ref HEAD)
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")

if [ -z "$UPSTREAM" ]; then
    echo "⚠️  WARNING: No tracking branch configured for @{u}"
    exit 0
fi

echo "🔍 [Pre-push] Running protocol_cli.py sync --dry-run (upstream: @{u})..."

export PYTHONPATH="$PROTOCOL_DIR:$PYTHONPATH"

python "$PROTOCOL_CLI" sync --dry-run
RESULT=$?

if [ $RESULT -eq 0 ]; then
    echo "✅ [Pre-push] Dry-run passed. Safe to push to @{u}."
    exit 0
else
    echo ""
    echo "❌ [Pre-push] Dry-run detected issues."
    echo "Fix issues and retry commit."
    exit 1
fi
