#!/usr/bin/env bash
# POST-COMMIT HOOK — CoderCerberus V0.02
# Token management, sync global, self-improvement loop.
# No bloquea commit si falla (informativo).

SCRIPTS_DIR="$(dirname "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")")/scripts"

# Token Management (compact + cache)
if [ -f "$SCRIPTS_DIR/token_manager.py" ]; then
    python "$SCRIPTS_DIR/token_manager.py" --compact --quiet 2>/dev/null || true
fi

# Sincronización Global Automática
if [ -f "$SCRIPTS_DIR/global_sync_safe.py" ]; then
    echo "🌍 [Post-commit] Sincronizando protocolo a proyectos de REGISTRY.json..."
    python "$SCRIPTS_DIR/global_sync_safe.py" --apply
fi

# Self-Improvement Loop — detecta gaps y documenta en HISTORIAL.md
if [ -f "$SCRIPTS_DIR/self_improvement_loop.py" ]; then
    echo "🔄 [Post-commit] Ejecutando self_improvement_loop (gaps → HISTORIAL.md)..."
    python "$SCRIPTS_DIR/self_improvement_loop.py" 2>/dev/null || true
fi

# Review Queue — encola commits que tocan tests/ o scripts/ para revision humana
if [ -f "$SCRIPTS_DIR/review_queue.py" ]; then
    python "$SCRIPTS_DIR/review_queue.py" --enqueue 2>/dev/null || true
fi

exit 0
