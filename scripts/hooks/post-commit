#!/usr/bin/env bash
# POST-COMMIT HOOK — FASE 8+9: Auto-triggering automation + Context management
# Ejecuta automáticamente: RTK compress, Headspace trigger, session export, auto-compact trigger
# No bloquea commit si falla (informativo)

SCRIPTS_DIR="$(dirname "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")")/scripts"

# FASE 8/9: Auto-Compresión y Optimización de Contexto
if [ -f "$SCRIPTS_DIR/token_optimizer.py" ]; then
    python "$SCRIPTS_DIR/token_optimizer.py" --compact --quiet 2>/dev/null || true
fi

# FASE 10: Sincronización Global Automática
if [ -f "$SCRIPTS_DIR/global_sync_safe.py" ]; then
    echo "🌍 [Post-commit] Sincronizando protocolo a proyectos de REGISTRY.json..."
    python "$SCRIPTS_DIR/global_sync_safe.py" --apply
fi

exit 0
