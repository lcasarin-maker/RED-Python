#!/bin/bash
# Pre-commit hook Coder Cerberus V0.1: Single authority protocol_cli.py

PROTOCOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PROTOCOL_CLI="$PROTOCOL_DIR/scripts/protocol_cli.py"

echo "🔍 [Pre-commit] Validando protocolo Coder Cerberus V0.1 con protocol_cli.py..."

# Skip validation if commit is --amend and no real changes
if git diff-index --quiet HEAD --; then
    echo "⏭️  [Pre-commit] Sin cambios, pasando"
    exit 0
fi

export PYTHONPATH="$PROTOCOL_DIR:$PYTHONPATH"

python "$PROTOCOL_CLI" check
RESULT=$?

if [ $RESULT -eq 0 ]; then
    echo "✅ [Pre-commit] EXCELENTE — Protocolo validado (6/6 dominios). Commit permitido."
    exit 0
else
    echo ""
    echo "❌ [Pre-commit] BLOQUEADO — Fallo en validación de protocolo Coder Cerberus V0.1."
    echo "Arregla los errores arriba y REINICIA el proceso de commit."
    exit 1
fi
