# Tokensaver_V1 — Exclusiones agresivas
# Ahorro: −30% a −50% input tokens

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Node.js
node_modules/
npm-debug.log
yarn-error.log
.npm/

# Git
.git/
.gitignore

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Documentación (carga después si necesita)
*.pdf
*.doc
*.docx

# Logs
logs/
*.log
error.log

# Temporales
tmp/
temp/
.tmp/
*.tmp

# Archivos grandes
*.zip
*.rar
*.7z
*.tar.gz
*.iso

# Caché
.cache/
*.cache

# Dependencias compiladas (mantener código fuente)
.venv/
venv/
env/
