#!/usr/bin/env bash
# POST-COMMIT HOOK — CoderCerberus V0.02
# Token management, sync global, self-improvement loop.
# No bloquea commit si falla (informativo).

if [ -d ".protocol-core" ]; then
    SCRIPTS_DIR="$(pwd)/.protocol-core/scripts"
    IS_SATELLITE=true
else
    SCRIPTS_DIR="$(dirname "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")")/scripts"
    IS_SATELLITE=false
fi

# Post-commit maintenance is opt-in to keep validation idempotent.
# Run it explicitly when you want to refresh cached history or review queues:
#   python scripts/protocol_cli.py maintenance
if [ "$CERBERUS_POSTCOMMIT_AUTOMATION" = "1" ] && [ -f "$SCRIPTS_DIR/protocol_cli.py" ]; then
    echo "🔄 [Post-commit] Ejecutando mantenimiento explícito..."
    python "$SCRIPTS_DIR/protocol_cli.py" maintenance
fi

exit 0
