#!/usr/bin/env bash
# PRE-PUSH HOOK Coder Cerberus V0.02: Rollback detection (Regla #29) + protocol_cli.py validation

set -e

PROTOCOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PROTOCOL_CLI="$PROTOCOL_DIR/scripts/protocol_cli.py"

BRANCH=$(git rev-parse --abbrev-ref HEAD)
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")

if [ -z "$UPSTREAM" ]; then
    echo "WARNING: No tracking branch configured for @{u}"
    exit 0
fi

# --- REGLA #29: Rollback Testing ---
# Detectar cambios destructivos: eliminaciones, migraciones, archivos criticos
has_destructive=$(git diff "${UPSTREAM}"...HEAD --name-status 2>/dev/null | grep -E "^[DR]|migrations/|AGENT\.md|CLAUDE\.md|SPEC\.md|scripts/hooks/" || true)

if [ -n "$has_destructive" ]; then
    echo "[Pre-push] Cambios destructivos detectados:"
    echo "$has_destructive"
    # Verificar que HISTORIAL.md tenga rollback test documentado
    if ! grep -q "Rollback Test.*PASSED\|Estado: PASSED" "$PROTOCOL_DIR/HISTORIAL.md" 2>/dev/null; then
        echo ""
        echo "ERROR (Regla #29): Cambios destructivos sin rollback test documentado."
        echo "Agrega una seccion 'Rollback Test Result: PASSED' a HISTORIAL.md antes de push."
        exit 1
    fi
    echo "[Pre-push] Rollback test verificado en HISTORIAL.md."
fi

# --- Protocol CLI sync validation ---
echo "[Pre-push] Ejecutando protocol_cli.py sync --dry-run (upstream: @{u})..."

export PYTHONPATH="$PROTOCOL_DIR:$PYTHONPATH"

python "$PROTOCOL_CLI" sync --dry-run
RESULT=$?

if [ $RESULT -eq 0 ]; then
    echo "[Pre-push] Dry-run passed. Safe to push to @{u}."
    exit 0
else
    echo ""
    echo "[Pre-push] Dry-run detected issues. Fix and retry."
    exit 1
fi
